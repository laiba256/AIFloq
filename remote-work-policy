<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Remote Work Policy — AiFloq</title>
<meta name="description" content="AiFloq is a fully remote company. Learn about our remote work policy, async culture, flexible hours, and worldwide team structure."/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<style>
  :root {
    --bg: #080C14;
    --surface: #0E1420;
    --surface2: #141B2D;
    --border: rgba(255,255,255,0.07);
    --accent: #0EA5E9;
    --accent2: #6EE7B7;
    --text: #F0F4FF;
    --muted: #8896B0;
    --white: #ffffff;
    --purple: #A78BFA;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 5%;
    background: rgba(8,12,20,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.4rem;
    letter-spacing: -0.03em;
    color: var(--white);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo span { color: var(--accent); }

  .nav-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    border: 1px solid var(--border);
    padding: 0.45rem 1rem;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .nav-back:hover { color: var(--accent); border-color: rgba(14,165,233,0.3); }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 8rem 5% 5rem;
    overflow: hidden;
    z-index: 1;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(14,165,233,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(14,165,233,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 100%);
  }

  .hero-glow {
    position: absolute;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(14,165,233,0.15) 0%, transparent 70%);
    top: -150px; right: -100px;
    pointer-events: none;
  }

  .hero-glow2 {
    position: absolute;
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(110,231,183,0.1) 0%, transparent 70%);
    bottom: 0; left: 5%;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 820px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(110,231,183,0.1);
    border: 1px solid rgba(110,231,183,0.3);
    color: var(--accent2);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--accent2);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    letter-spacing: -0.04em;
    line-height: 1.08;
    margin-bottom: 1.25rem;
  }

  .hero-title em {
    font-style: normal;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    color: var(--muted);
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 2.5rem;
  }

  /* Summary chips */
  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.6rem 1.1rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text);
  }

  .chip-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  /* ── CONTENT ── */
  .content {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 5% 6rem;
    position: relative;
    z-index: 1;
  }

  /* Summary card */
  .summary-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2rem 2.5rem;
    margin-bottom: 3rem;
    position: relative;
    overflow: hidden;
  }

  .summary-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent2), var(--accent));
  }

  .summary-card p {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.8;
    font-weight: 300;
  }

  .summary-card strong { font-weight: 600; color: var(--accent2); }

  /* Benefits grid */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .benefit-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }

  .benefit-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(14,165,233,0.4), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .benefit-card:hover {
    border-color: rgba(14,165,233,0.25);
    transform: translateY(-3px);
  }

  .benefit-card:hover::before { opacity: 1; }

  .benefit-icon {
    font-size: 1.75rem;
    margin-bottom: 1rem;
    display: block;
  }

  .benefit-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .benefit-desc {
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.65;
    font-weight: 300;
  }

  /* Policy sections */
  .policy-section {
    margin-bottom: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .policy-section:last-of-type { border-bottom: none; }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .section-label::before {
    content: '';
    width: 16px; height: 1px;
    background: var(--accent);
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.85rem;
  }

  .policy-section p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 0.85rem;
  }

  .policy-section p:last-child { margin-bottom: 0; }

  .policy-section ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 0.5rem 0 0.85rem;
  }

  .policy-section ul li {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.88rem;
    color: var(--muted);
    font-weight: 300;
    line-height: 1.6;
  }

  .policy-section ul li::before {
    content: '→';
    color: var(--accent2);
    font-size: 0.72rem;
    flex-shrink: 0;
    margin-top: 3px;
  }

  .policy-section strong { color: var(--text); font-weight: 600; }

  /* Highlight box */
  .highlight-box {
    background: rgba(110,231,183,0.05);
    border: 1px solid rgba(110,231,183,0.2);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin: 1rem 0;
  }

  .highlight-box p {
    color: var(--text) !important;
    margin: 0 !important;
  }

  /* Tools row */
  .tools-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  .tool-chip {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.72rem;
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
    font-weight: 500;
  }

  /* Section heading dividers */
  .section-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.6rem;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 3rem 0 1.75rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .section-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* Contact box */
  .contact-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    margin-top: 3rem;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .contact-box::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent2), var(--accent));
  }

  .contact-box h3 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .contact-box p {
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 300;
    margin-bottom: 1.25rem;
  }

  .contact-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .contact-chip {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.6rem 1.1rem;
    font-size: 0.82rem;
    color: var(--text);
    font-weight: 500;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .contact-chip:hover { border-color: rgba(110,231,183,0.35); color: var(--accent2); }

  /* ── FOOTER ── */
  footer {
    background: var(--bg);
    border-top: 1px solid var(--border);
    padding: 2rem 5%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }

  .footer-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--white);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .footer-logo span { color: var(--accent); }
  .footer-copy { color: var(--muted); font-size: 0.8rem; }

  .footer-links { display: flex; gap: 1.5rem; }

  .footer-links a {
    color: var(--muted);
    font-size: 0.8rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--accent); }
  .footer-links a.active { color: var(--accent2); }

  @media (max-width: 900px) {
    .benefits-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .benefits-grid { grid-template-columns: 1fr; }
    .hero-chips { flex-direction: column; }
    footer { flex-direction: column; text-align: center; }
  }
</style>
</head>
