<!-- CONTENT -->
<div class="policy-content">

  <!-- TOC -->
  <div class="toc">
    <div class="toc-title">Table of Contents</div>
    <ul class="toc-list">
      <li><a href="#s1">1. Information We Collect</a></li>
      <li><a href="#s2">2. How We Use Your Information</a></li>
