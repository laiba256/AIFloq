    <div class="policy-meta">
      <div class="policy-meta-item">📅 <strong>Effective Date:</strong> May 8, 2026</div>
      <div class="policy-meta-item">🔄 <strong>Last Updated:</strong> May 8, 2026</div>
      <div class="policy-meta-item">🏢 <strong>Company:</strong> AiFloq</div>
    </div>
